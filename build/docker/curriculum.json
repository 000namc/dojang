      "exercises": [
        {
          "title": "컨테이너 실행",
          "description": "`alpine` 이미지로 `echo 'Hello Docker!'`를 실행하세요.\n\n실행 후 자동으로 삭제되도록 하세요.",
          "initial_code": "docker run",
          "check_type": "ai_check",
          "difficulty": 1
        },
        {
          "title": "백그라운드 실행",
          "description": "`nginx:alpine`을 **백그라운드**로 실행하고 `my-nginx`라는 이름을 지정하세요.\n\n그 후 `docker ps`로 확인하세요.",
          "initial_code": "docker run",
          "check_type": "ai_check",
          "difficulty": 2
        }
      ]
    },
    {
